# ──────────────────────────────────────────────
# Ffads — Environment Configuration
# Use EXPO_PUBLIC_ prefix so Expo auto-exposes these
# ──────────────────────────────────────────────

# ─── Google Gemini AI ─────────────────────────
# Put your Gemini API key here as a fallback (also manageable in Profile → API tab)

# ─── Supabase ─────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ─── Open Food Facts ─────────────────────────
EXPO_PUBLIC_OFF_API_BASE_URL=https://world.openfoodfacts.org/api/v2
EXPO_PUBLIC_OFF_USERNAME=
EXPO_PUBLIC_OFF_PASSWORD=

# ─── App Settings ────────────────────────────
EXPO_PUBLIC_APP_ENV=development
