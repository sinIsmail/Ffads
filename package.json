{
  "name": "ffadz",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "dev:lan": "expo start --dev-client --lan --port 8089 --max-workers 2",
    "dev:tunnel": "expo start --dev-client --tunnel --port 8089 --max-workers 2",
    "dev:ngrok": "powershell -ExecutionPolicy Bypass -File ./RUN_DEV_NGROK.ps1",
    "dev:cloudflare": "powershell -ExecutionPolicy Bypass -File ./RUN_DEV_CLOUDFLARE.ps1",
    "dev:localtunnel": "powershell -ExecutionPolicy Bypass -File ./RUN_DEV_LOCALTUNNEL.ps1",
    "dev:localhostrun": "powershell -ExecutionPolicy Bypass -File ./RUN_DEV_LOCALHOSTRUN.ps1",
    "build:dev:android": "eas build --profile development --platform android",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@react-navigation/stack": "^7.8.9",
    "@supabase/supabase-js": "^2.101.1",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-print": "^55.0.13",
    "expo-sharing": "^55.0.18",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
